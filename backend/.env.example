# ================================================
# SmartContainer Risk Engine — Environment Variables
# Copy this file to .env and fill in the values
# NEVER commit .env to version control
# ================================================

# ── Server ──────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Database ────────────────────────────────────
DATABASE_URL="postgresql://smartuser:smartpass@localhost:5432/smart_container?schema=public"

# ── Redis ───────────────────────────────────────
REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=yourredispassword  # Uncomment if Redis has auth

# ── JWT ─────────────────────────────────────────
# Generate strong secrets: node -e "require('crypto').randomBytes(64).toString('hex')|clip"
JWT_ACCESS_SECRET=change_me_to_a_long_random_secret_at_least_64_chars
JWT_REFRESH_SECRET=change_me_to_another_long_random_secret_at_least_64_chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── ML Service ──────────────────────────────────
ML_SERVICE_URL=http://localhost:8000
ML_SERVICE_API_KEY=change_me_internal_api_key_must_match_ml_service

# ── CORS ────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3001

# ── Rate Limiting ───────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# ── File Upload ─────────────────────────────────
UPLOAD_MAX_SIZE_MB=10
UPLOAD_DIR=./uploads

# ── Logging ─────────────────────────────────────
LOG_LEVEL=debug
